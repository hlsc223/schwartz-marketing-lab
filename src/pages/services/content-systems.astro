---
// Ported from client/src/pages/ServiceStrategyExecution.tsx in the legacy Replit repo.
import Layout from '../../layouts/Layout.astro';
import ServiceLayout from '../../components/ServiceLayout.astro';
import { faqPageSchema } from '../../lib/schema';
import { getEntry } from 'astro:content';

const seo = await getEntry('seo', 'content-systems');
if (!seo) throw new Error('Missing seo/content-systems.yaml entry');

const faqItems = [
  {
    question: 'What does a content marketing consultant do?',
    answer:
      'A content marketing consultant helps turn expertise into a repeatable strategy for attracting, educating, and converting the right audience. At S.LAB, that includes content strategy, editorial planning, content systems, repurposing frameworks, and measurement so content becomes a long-term growth asset instead of a one-off campaign.',
  },
  {
    question: 'How is content strategy different from content production?',
    answer:
      'Content strategy determines what to create, why it matters, who it serves, and how it supports business goals. Content production is the execution of that strategy. Strong content programs need both: a clear strategic foundation and a system for turning ideas into consistent, high-quality assets.',
  },
  {
    question: 'Do you only build the strategy, or do you also create the content?',
    answer:
      'Both options are available depending on the engagement. S.LAB can build the strategy and workflows for your internal team, collaborate with existing vendors, or help execute the content directly. Every engagement starts with the system, then moves into the level of execution support your team needs.',
  },
  {
    question: 'What kinds of content can the system produce?',
    answer:
      'A strong content system can support articles, newsletters, case studies, thought leadership, social posts, sales enablement assets, executive content, email sequences, and campaign materials. The goal is to turn one strong idea or source of expertise into multiple useful assets across the channels your audience actually uses.',
  },
  {
    question: 'How long does content marketing take to show results?',
    answer:
      'Early improvements can happen quickly when messaging, internal links, and existing content are cleaned up. Larger gains usually take several months because content marketing compounds through search visibility, AI citations, backlinks, audience trust, and repeated exposure. The goal is to build assets that become more valuable over time.',
  },
  {
    question: 'What is content atomization?',
    answer:
      'Content atomization is the process of turning one substantial idea, interview, webinar, report, or article into multiple smaller assets. For example, one founder interview might become a blog post, LinkedIn posts, newsletter copy, sales talking points, and short-form clips. It helps teams get more value from the expertise they already have.',
  },
];

const schema = faqPageSchema(faqItems);
---

<Layout
  title={seo.data.title}
  description={seo.data.description}
  canonicalPath="/services/content-systems"
  schema={schema}
>
  <ServiceLayout
    serviceLabel="Content Systems"
    headline="Content marketing consulting that compounds."
    subhead="Build a repeatable system that transforms ideas, conversations, and customer insights into content that compounds across every channel."
    sectionHeading="Most teams have the content."
    overview={[
      'Most companies are not short on expertise.',
      'They are short on systems.',
      'The best content programs do not start from scratch every week. They capture what already exists — customer questions, founder insight, sales conversations, webinars, podcasts, product knowledge — and turn it into assets that support every stage of the funnel.',
      'S.LAB builds the strategy, workflows, and content engine that keeps valuable ideas from getting lost, then helps execute the work that brings the system to life.',
      'Built well, that same content becomes the foundation for <a href="/services/answer-engine-optimization" class="inline-link">answer engine optimization</a> — the structure AI systems need to find and cite it.',
    ]}
    whatIncluded={[
      {
        title: 'Content Audit',
        description: 'A clear assessment of what exists, what is working, what is outdated, and where the biggest content opportunities are.',
      },
      {
        title: 'Editorial Strategy',
        description: 'Content pillars, funnel mapping, audience priorities, and a roadmap that gives every piece a reason to exist.',
      },
      {
        title: 'Content Atomization Framework',
        description: 'A repeatable system for turning one high-value idea, interview, podcast, webinar, or report into many channel-specific assets.',
      },
      {
        title: 'Pillar Content Development',
        description: 'Flagship assets built to anchor campaigns, support search, educate buyers, and create material worth repurposing.',
      },
      {
        title: 'Lifecycle & Distribution Content',
        description: 'Newsletters, nurture emails, social content, and supporting assets that move ideas across the channels your audience actually uses.',
      },
      {
        title: 'Measurement & Optimization',
        description: 'A practical reporting system for tracking what is working, improving what is not, and tying content back to business goals.',
      },
    ]}
    cardIcons={['clipboard-list', 'layout-list', 'layers', 'book-open', 'mail', 'bar-chart-2']}
    processTitle="How we build your content flywheel"
    process={[
      { number: '01', title: 'Capture & Audit', description: 'Identify your strongest existing assets, expertise, buyer questions, and content opportunities.' },
      { number: '02', title: 'Build the System', description: 'Create the editorial roadmap, content pillars, workflows, repurposing framework, and production process.' },
      { number: '03', title: 'Create & Repurpose', description: 'Turn ideas into articles, newsletters, case studies, social content, sales assets, and campaign materials.' },
      { number: '04', title: 'Optimize & Scale', description: 'Track what works, improve the system, and keep the content engine compounding over time.' },
    ]}
    whoItsFor={`Teams creating content without a clear system\nFounders with expertise but no repeatable way to turn it into content\nMarketing teams stretched across too many channels\nBrands investing in content but struggling to prove impact\nCompanies trying to get more value from existing content`}
    testimonialQuote="Quinn is one of the most talented writers I've had the pleasure of working with. His ability to capture the vision and value propositions across any project and translate them into copy that's both easy to read and genuinely compelling is unmatched. He brings a rare and valuable blend of strategic thinking and hands-on execution."
    testimonialAuthor="Olivia McNaughten"
    testimonialRole="Director, Product GTM · ShopMy (formerly @ GRIN)"
    proofPoints={[
      { stat: '1 Idea', label: 'many assets' },
      { stat: '1 System', label: 'every channel' },
      { stat: '1 Strategy', label: 'compounding growth' },
    ]}
    proofRows={[
      { client: 'Content Atomization', category: '', result: 'One Idea, Many Assets' },
      { client: 'Editorial Operations', category: '', result: 'Repeatable Publishing System' },
      { client: 'Measurement & Optimization', category: '', result: 'Content Tied to Business Goals' },
    ]}
    faqItems={faqItems}
    ctaLabel="S.LAB"
  />
</Layout>

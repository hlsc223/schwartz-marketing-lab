---
// Ported from client/src/pages/ServiceAeoGeo.tsx in the legacy Replit repo —
// every headline, stat, process step, deliverable, testimonial, FAQ, and
// proof row below is copied verbatim from that file's default props, run
// through the new ServiceLayout.astro (see that file's port notes).
import Layout from '../../layouts/Layout.astro';
import ServiceLayout from '../../components/ServiceLayout.astro';
import { faqPageSchema } from '../../lib/schema';
import { getEntry } from 'astro:content';

const seo = await getEntry('seo', 'answer-engine-optimization');
if (!seo) throw new Error('Missing seo/answer-engine-optimization.yaml entry');

const faqItems = [
  {
    question: 'What is AEO?',
    answer:
      "Answer Engine Optimization is the practice of structuring your content and technical foundation so AI systems like ChatGPT, Perplexity, and Google's AI Overviews can find, understand, and cite your brand when answering user questions.",
  },
  {
    question: "What's the difference between SEO and AEO?",
    answer:
      'SEO optimizes for ranking in traditional search results. AEO optimizes for being the source an AI system pulls from and cites when generating an answer. They share a foundation — technical health, content quality, topical authority — but AEO adds structured data, clear entity definitions, and answer-ready formatting that AI systems specifically reward.',
  },
  {
    question: 'Is SEO still important?',
    answer:
      "Yes. AI Overviews and chat-based answers still draw heavily on sites with strong traditional SEO foundations — crawlability, site speed, topical authority, and backlink profile. AEO builds on top of SEO, it doesn't replace it.",
  },
  {
    question: 'Which AI platforms does AEO target?',
    answer:
      "We optimize for visibility across Google's AI Overviews, ChatGPT, Perplexity, Claude, and emerging answer engines — plus the platforms that feed them, like Reddit and YouTube, which AI systems frequently cite as sources.",
  },
  {
    question: 'How long does answer engine optimization take to show results?',
    answer:
      'Most clients see initial visibility gains within the first week as we stabilize technical and structural issues. Meaningful, compounding share-of-voice growth typically builds over 60–90 days as content and authority signals accumulate.',
  },
];

const schema = faqPageSchema(faqItems);
---

<Layout
  title={seo.data.title}
  description={seo.data.description}
  canonicalPath="/services/answer-engine-optimization"
  schema={schema}
>
  <ServiceLayout
    serviceLabel="SEO & AEO"
    headline="Answer engine optimization that drives revenue."
    subhead="S.LAB puts you front and center across the discovery surfaces your audience trusts most. Then we turn that visibility into revenue for your brand."
    sectionHeading="What Is Answer Engine Optimization?"
    overview={[
      "Answer Engine Optimization is the discipline of structuring your content and technical foundation so AI systems — ChatGPT, Perplexity, Google's AI Overviews — can find, understand, and cite your brand when answering the questions your buyers are asking.",
      "It builds on the same foundation as traditional SEO — crawlability, site health, topical authority — but adds the structured data, clear entity definitions, and answer-ready formatting that AI systems specifically reward.",
      "We treat AEO and SEO as one system, not two competing disciplines. The goal is the same either way: be the source that gets found, cited, and trusted.",
    ]}
    whatIncluded={[
      {
        title: 'Modern Search Visibility Audit',
        description:
          "A full assessment of where you currently appear — and where you're invisible — across Google, AI Overviews, ChatGPT, Perplexity, and the platforms that feed them.",
      },
      {
        title: 'Technical & Content Health Review',
        description:
          'Crawlability, site speed, structured data, and content quality checked against what both traditional search engines and AI systems need to surface and cite you.',
      },
      {
        title: 'Revenue Opportunity Assessment',
        description:
          'Visibility gaps mapped against your actual revenue opportunities, so prioritization is based on business impact, not just search volume.',
      },
      {
        title: '90-Day Action Plan',
        description:
          "A prioritized, sequenced roadmap — what to fix first, what to build next, and what to monitor — built around your team's capacity and your buyers' search behavior.",
      },
      {
        title: 'Reporting & Measurement Dashboard',
        description:
          'Ongoing visibility tracking across search engines and AI answer engines, so you can see share-of-voice growth as it happens, not months later.',
      },
      {
        title: 'Execution & Strategic Support',
        description:
          'Hands-on support implementing the roadmap — not just a deck, an actual partner executing alongside your team.',
      },
    ]}
    whatIncludedSubtext="Six deliverables. Built around your visibility, your revenue, and your team."
    cardIcons={['scan-search', 'file-search', 'trending-up', 'route', 'layout-dashboard', 'users']}
    processTitle="How we make your brand the answer"
    process={[
      { number: '01', title: 'Audit', description: 'We map your current visibility across every search and AI surface that matters to your buyers.' },
      { number: '02', title: 'Stabilize', description: 'We fix the technical and structural issues blocking search engines and AI systems from understanding your site.' },
      { number: '03', title: 'Prioritize', description: 'We rank opportunities by revenue impact, not just traffic potential.' },
      { number: '04', title: 'Build', description: 'We create and structure the content and data needed to earn citations and rankings.' },
      { number: '05', title: 'Iterate', description: "We track what's working across every surface and compound it — dropping what isn't." },
    ]}
    whoItsFor={`Brands impacted by Google updates that crushed their organic visibility overnight\nTeams that need to understand how AI search is changing the way buyers find them\nCompanies investing heavily in content but seeing no compounding return\nCategory leaders defending share of voice against faster-moving competitors\nMarketing teams that need visibility results their leadership can see and trust`}
    testimonialQuote="We saw a 43% lift in share of voice within the first quarter of working together. They didn't just hand us a report — they helped us actually execute."
    testimonialAuthor="Natasha Zapanta"
    testimonialRole="Lifecycle Marketing & Marketing Ops · Nooks"
    proofPoints={[
      { stat: '<7 days', label: 'avg. time to first visibility gains' },
      { stat: '8+', label: 'search and AI surfaces audited' },
      { stat: '100%', label: 'of visibility gaps documented' },
    ]}
    proofRows={[
      { client: 'Nooks', category: 'SEO & AEO', result: '43% Share of Voice Growth' },
      { client: 'Search Party', category: 'Executive Authority', result: 'Top 4 Across High-Intent AI Prompts' },
      { client: 'GRIN', category: 'Content Systems', result: '100K+ Monthly Pageviews' },
    ]}
    faqItems={faqItems}
    ctaLabel="AEO"
  />
</Layout>

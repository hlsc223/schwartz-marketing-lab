---
// Ported from client/src/pages/ServicePrMedia.tsx in the legacy Replit repo.
import Layout from '../../layouts/Layout.astro';
import ServiceLayout from '../../components/ServiceLayout.astro';
import { faqPageSchema } from '../../lib/schema';
import { getEntry } from 'astro:content';

const seo = await getEntry('seo', 'pr-media');
if (!seo) throw new Error('Missing seo/pr-media.yaml entry');

const faqItems = [
  {
    question: 'Do you guarantee media placements?',
    answer:
      "No. No responsible PR partner should guarantee specific placements. What we do instead is build a compelling narrative, identify the right opportunities, pitch consistently, and create the assets needed to improve your chances of earning meaningful coverage. The goal isn't random press. It's credible visibility in places your buyers already trust.",
  },
  {
    question: 'Which publications and podcasts do you target?',
    answer:
      "It depends on your audience and category. Sometimes the best opportunity is a major publication. Other times, it is a niche industry podcast, newsletter, or trade site your buyers actually trust. The goal is not to appear everywhere. It's to appear where trust is created.",
  },
  {
    question: 'Do you handle both outreach and content creation?',
    answer:
      'Yes. S.LAB supports the full process: narrative development, media targeting, outreach, quote responses, article drafting, podcast preparation, contributed content, and post-placement repurposing. Every placement becomes an asset that can be reused across your website, sales process, newsletters, and social channels.',
  },
  {
    question: 'How is this different from traditional PR?',
    answer:
      'Traditional PR often stops at the placement. S.LAB focuses on the full authority footprint: what story you tell, where it appears, how buyers discover it, and how AI systems, search engines, journalists, and prospects encounter it over time. Every placement is designed to compound into additional trust, visibility, and authority.',
  },
  {
    question: 'How long does it take to see results?',
    answer:
      'Some opportunities move quickly, especially quotes, podcasts, and niche publications. Larger placements often take longer. The strongest results come from consistent outreach over time as your narrative becomes clearer, your authority footprint expands, and trust compounds across channels.',
  },
  {
    question: 'Why does PR matter for AI search?',
    answer:
      "Because AI systems lean on third-party sources to decide which companies, products, and experts deserve attention. Mentions in publications, podcasts, industry sites, reviews, and expert commentary strengthen the authority signals that influence modern discovery. Strong PR doesn't just build credibility with people — it shapes how AI systems understand and recommend your brand.",
  },
];

const schema = faqPageSchema(faqItems);
---

<Layout
  title={seo.data.title}
  description={seo.data.description}
  canonicalPath="/services/pr-media"
  schema={schema}
>
  <ServiceLayout
    serviceLabel="PR & Media"
    headline="Thought leadership PR for B2B executives."
    subhead="Build authority through publications, podcasts, reviews, and industry media that shape how buyers discover and evaluate your brand."
    sectionHeading="Why third-party trust matters."
    overview={[
      "Buyers don't just learn about your company from your website.",
      'They discover you through articles, podcasts, reviews, newsletters, industry communities, and recommendations from people they already trust.',
      'The brands that consistently appear in those conversations build credibility faster, earn more attention, and shape how their category understands them.',
      'PR & Media is about intentionally creating that footprint — helping the right people tell the right story about your business in the places that matter most.',
      'AI visibility benefits from this too, but trust is the real headline. It pairs directly with <a href="/services/executive-authority">executive authority</a> work — the more credible the voice, the more compelling the placement.',
    ]}
    whatIncluded={[
      {
        title: 'Narrative & Messaging Strategy',
        description: 'The story, positioning, and proof points that make your company worth covering and easier to understand.',
      },
      {
        title: 'Media Outreach & Placements',
        description: 'Targeted outreach to relevant publications, newsletters, reporters, editors, and industry sites where your buyers pay attention.',
      },
      {
        title: 'Podcast Strategy & Booking',
        description: 'Podcast targeting, outreach, prep, and appearance opportunities for founders and executives with something meaningful to say.',
      },
      {
        title: 'Expert Source Positioning',
        description: 'Quote opportunities, journalist responses, and expert commentary that position your team as credible voices in your category.',
      },
      {
        title: 'Bylined Articles & Guest Contributions',
        description: 'Founder- or executive-led articles, guest posts, and contributed content that bring your point of view into trusted third-party environments.',
      },
      {
        title: 'Review & Reputation Management',
        description: 'Review site strategy, reputation signals, and third-party proof that support buyer research and strengthen trust before the sales conversation.',
      },
    ]}
    whatIncludedSubtext="Every placement compounds. Coverage builds credibility, credibility earns trust, and trust shapes how buyers discover and evaluate your brand."
    cardIcons={['message-circle', 'newspaper', 'mic', 'quote', 'pen-line', 'star']}
    process={[
      { number: '01', title: 'Narrative & Positioning', description: 'Before outreach, we define the stories, perspectives, and differentiators worth amplifying.' },
      { number: '02', title: 'Target & Pitch', description: 'We identify the publications, podcasts, newsletters, and opportunities most relevant to your audience.' },
      { number: '03', title: 'Place & Publish', description: 'We manage outreach, coordinate content creation, and secure placements that reinforce your positioning.' },
      { number: '04', title: 'Amplify & Repurpose', description: 'Every placement becomes additional assets: social content, newsletters, sales collateral, website proof, and future media opportunities.' },
    ]}
    whoItsFor={`Brands entering new markets and needing credibility quickly\nCompanies competing against larger, more established players\nFounders and marketing teams with a strong story but limited visibility\nBusinesses that want buyers to find trustworthy proof before sales conversations\nTeams that need authority, trust, and visibility beyond their own website`}
    testimonialQuote="Working with Quinn stood out because he moved quickly, brought original thinking to ambiguous problems, and translated messy founder context into clear public-facing ideas. He helped us show up credibly alongside more established companies and turn early observations into usable frameworks."
    testimonialAuthor="Brandon Brown"
    testimonialRole="CEO & Co-Founder · Joymore (formerly @ Search Party)"
    proofPoints={[
      { stat: 'Earned Authority', label: 'third-party validation' },
      { stat: 'Trusted Sources', label: 'publications, podcasts & industry media' },
      { stat: 'Narrative Control', label: 'shape what buyers discover' },
    ]}
    proofBandLabel="Results & Capabilities"
    proofRows={[
      { client: 'Positioning & Messaging', category: '', result: 'Stronger Category Positioning' },
      { client: 'Media & Podcast Outreach', category: '', result: 'More Trusted Third-Party Mentions' },
      { client: 'Guest Contributions & Expert Sourcing', category: '', result: 'Greater Visibility Across Search and AI' },
    ]}
    faqTitle="PR & Media FAQs"
    faqItems={faqItems}
    ctaLabel="PR"
  />
</Layout>

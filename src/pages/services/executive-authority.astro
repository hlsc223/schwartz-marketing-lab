---
// Ported from client/src/pages/ServiceThoughtLeadership.tsx in the legacy Replit repo.
import Layout from '../../layouts/Layout.astro';
import ServiceLayout from '../../components/ServiceLayout.astro';
import { faqPageSchema } from '../../lib/schema';
import { getEntry } from 'astro:content';

const seo = await getEntry('seo', 'executive-authority');
if (!seo) throw new Error('Missing seo/executive-authority.yaml entry');

const faqItems = [
  {
    question: 'What is executive thought leadership?',
    answer:
      "Executive thought leadership is the practice of consistently sharing informed perspectives on the topics your buyers care about, in the channels where they pay attention. It's not about broadcasting credentials — it's about demonstrating judgment. Done well, it shortens sales cycles, attracts inbound opportunities, and builds the kind of trust that advertising can't buy.",
  },
  {
    question: "What's the difference between executive branding and personal branding?",
    answer:
      "Personal branding applies to anyone building a public presence. Executive branding is specifically about positioning a business leader as a credible voice in their industry in a way that creates commercial value — not just personal recognition. The goal isn't fame. It's trust with the right buyers.",
  },
  {
    question: 'Why is LinkedIn the primary channel for B2B executive authority?',
    answer:
      "LinkedIn is where B2B buyers, investors, and partners actively look for perspective from people they're considering working with. No other platform has the same combination of professional context and buyer intent. That said, LinkedIn is one channel in a broader system — newsletters, long-form content, Reddit, and other owned channels all play a role in building durable authority.",
  },
  {
    question: 'Do you handle content creation or just strategy?',
    answer:
      'Both. S.LAB can provide the strategy, editorial direction, and ghostwritten content — or work alongside your existing team if you prefer. Every engagement is built around what the executive actually needs, not a fixed production model.',
  },
  {
    question: 'What results should I expect from an executive authority program?',
    answer:
      'Early results are typically qualitative — better conversations, stronger inbound quality, recognition from people in your category. Quantitative results like pipeline attribution and measurable share of voice typically emerge over 3–6 months as content compounds and distribution grows. Executive authority is a long-term asset, not a short-term campaign.',
  },
  {
    question: 'How long does it take to build executive authority?',
    answer:
      'Most executives see meaningful momentum within 90 days of consistent, strategic publishing. Real authority — the kind where buyers already know your perspective before they reach out — typically takes 6–12 months. The earlier you start, the more the asset compounds.',
  },
];

const schema = faqPageSchema(faqItems);
---

<Layout
  title={seo.data.title}
  description={seo.data.description}
  canonicalPath="/services/executive-authority"
  schema={schema}
>
  <ServiceLayout
    serviceLabel="Executive Authority"
    headline="Your voice is the brand."
    subhead="Establish a credible, consistent presence through ghostwriting and strategic positioning — without spending your week writing."
    sectionHeading="Your expertise is an asset."
    overview={[
      "In modern B2B markets, people trust expertise before they trust brands. The voice of the founders, executives, and operators on the front lines of the industry often becomes a company's most powerful growth lever. We help turn your expertise into consistent content that builds credibility and elevates the brand behind it.",
    ]}
    whatIncluded={[
      {
        title: 'LinkedIn Executive Authority',
        description: 'Founder content, commentary, and industry positioning built to establish a consistent presence where buyers already pay attention.',
      },
      {
        title: 'Founder Newsletter Program',
        description: 'Audience-building newsletters that educate, nurture trust, and keep your perspective in front of the people who matter.',
      },
      {
        title: 'Long-Form Authority Content',
        description: 'Scripts and outlines that turn your expertise into long-form authority content buyers and answer engines can learn from.',
      },
      {
        title: 'Reddit Authority Strategy',
        description: 'Community research, post ideas, and thoughtful participation strategies that help your brand show up credibly in relevant conversations.',
      },
      {
        title: 'Positioning & Narrative Development',
        description: 'Clear points of view, category angles, and recurring themes that help you own the conversations worth owning.',
      },
      {
        title: 'Content Repurposing Engine',
        description: 'A system for turning podcasts, webinars, sales calls, interviews, and internal conversations into publishable authority assets.',
      },
    ]}
    cardIcons={['share-2', 'mail', 'play', 'message-square', 'fingerprint', 'refresh-cw']}
    processTitle="How we build executive authority"
    process={[
      { number: '01', title: 'Capture', description: 'We capture your expertise through structured conversations and turn it into a repeatable source of content.' },
      { number: '02', title: 'Distill', description: 'Identify the positions, narratives, insights, and ideas worth owning. What you actually believe, clearly stated.' },
      { number: '03', title: 'Publish', description: 'Turn those ideas into content across LinkedIn, newsletters, Reddit, YouTube, and owned channels — done-for-you, in your voice.' },
      { number: '04', title: 'Compound', description: 'We study what resonates and double down on the ideas that strengthen your authority.' },
    ]}
    whoItsFor={`Founders who know they should publish but don't have time\nExecutives with strong ideas but no consistent content system\nB2B teams that need trust built before the sales call\nCompanies where the founder's expertise is part of the brand advantage\nLeaders who want authority content without sounding outsourced`}
    testimonialQuote="Working with Quinn stood out because he moved quickly, brought original thinking to ambiguous problems, and translated messy founder context into clear public-facing ideas. He was a strong ghostwriting and newsletter partner: fast, creative, collaborative, and dependable. I'd recommend him to founders who need someone who can sharpen the narrative and turn high-level strategy into writing people actually want to read."
    testimonialAuthor="Brandon Brown"
    testimonialRole="CEO & Co-Founder · Joymore (formerly @ Search Party)"
    proofPoints={[
      { stat: '1 conversation', label: 'captured each week' },
      { stat: '5+ assets', label: 'from every recording' },
      { stat: '30 min', label: 'founder time required' },
    ]}
    proofRows={[
      { client: 'Search Party', category: 'Executive Authority', result: 'Top 4 Across High-Intent AI Prompts' },
      { client: 'Search Party', category: 'Newsletter', result: '3K+ Newsletter Subscribers' },
      { client: 'Nooks', category: 'SEO & AEO', result: '43% Share of Voice Growth' },
    ]}
    faqItems={faqItems}
    ctaLabel="TL"
  />
</Layout>

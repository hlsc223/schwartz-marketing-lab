---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog | Schwartz Marketing Lab"
  description="AEO, SEO, and content strategy insights for B2B brands trying to get found in AI search and modern discovery systems."
  canonicalPath="/blog"
>
  <div class="wrapper">
    <section class="page-hero">
      <span class="eyebrow">Blog</span>
      <h1>Insights on getting found.</h1>
      <p class="intro">
        Practical writing on AEO, SEO, and content strategy — for brands trying to stay visible as discovery
        shifts from search results to AI-generated answers.
      </p>
    </section>

    <section class="content-section">
      {posts.length === 0 ? (
        <p>New posts are on the way. Check back soon.</p>
      ) : (
        <div class="post-grid">
          {posts.map((post) => (
            <a class="post-card" href={`/blog/${post.id}`}>
              <span class="post-date">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </a>
          ))}
        </div>
      )}
    </section>
  </div>
</Layout>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 1.5rem;
    border-bottom: var(--border-frame);
    color: var(--color-text);
  }

  .post-date {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .post-card h2 {
    font-size: 1.3rem;
  }

  .post-card p {
    color: var(--color-text-muted);
    margin: 0;
  }
</style>

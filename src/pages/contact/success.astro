---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Thanks for reaching out | Schwartz Marketing Lab"
  description="Thanks for getting in touch with Schwartz Marketing Lab. We'll follow up shortly."
  canonicalPath="/contact/success"
>
  <div class="wrapper">
    <section class="page-hero">
      <span class="eyebrow">Contact</span>
      <h1>Thanks — we've got it.</h1>
      <p class="intro">
        Your message is in. We'll follow up shortly to set up a time to talk.
      </p>
      <div class="hero-cta">
        <a class="button" href="/">Back to homepage</a>
      </div>
    </section>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Schwartz Marketing Lab"
  description="Book a strategy call with Schwartz Marketing Lab to talk through AEO, content strategy, and authority building for your B2B brand."
  canonicalPath="/contact"
>
  <div class="wrapper">
    <section class="page-hero">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk about getting you found.</h1>
      <p class="intro">
        Tell us a bit about where you're at and what you're trying to solve. We'll follow up to set up a call.
      </p>
    </section>

    <section class="content-section">
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contact/success"
        class="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden-field">
          <label>
            Don't fill this out if you're human: <input name="bot-field" />
          </label>
        </p>

        <label class="field">
          <span>Name</span>
          <input type="text" name="name" required />
        </label>

        <label class="field">
          <span>Email</span>
          <input type="email" name="email" required />
        </label>

        <label class="field">
          <span>Company</span>
          <input type="text" name="company" />
        </label>

        <label class="field">
          <span>What are you trying to solve?</span>
          <textarea name="message" rows="5" required></textarea>
        </label>

        <button type="submit" class="button">Send</button>
      </form>
    </section>
  </div>
</Layout>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 560px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-family: var(--font-heading);
    font-size: 0.95rem;
  }

  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    border: var(--border-frame);
    background: var(--color-bg);
    color: var(--color-text);
    padding: 0.7rem 0.85rem;
    border-radius: 0;
  }

  .field input:focus,
  .field textarea:focus {
    outline: 1px solid var(--color-accent);
  }

  .hidden-field {
    display: none;
  }

  .contact-form button {
    align-self: flex-start;
  }
</style>

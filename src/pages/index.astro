    </div>
  </section>

  <!-- ============ TESTIMONIALS — ported from TestimonialsSection.tsx ============ -->
  <section id="testimonials" class="relative bg-background text-foreground py-24 md:py-32">
    <div class="container mx-auto px-4 md:px-6 max-w-6xl">
      <div class="mb-24 md:mb-28 max-w-3xl">

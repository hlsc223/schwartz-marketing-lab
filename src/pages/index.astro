---
// Homepage — ported directly from the legacy Replit repo's component tree:
//   client/src/pages/Home.tsx (section order, FAQ copy, document title)
//   client/src/components/Hero.tsx
//   client/src/components/TestimonialsSection.tsx
//   client/src/components/ServicesSection.tsx
//   client/src/components/CaseStudiesSection.tsx
//   client/src/components/FaqSection.tsx
// See the migration write-up for the full per-section reuse/port/rewrite/remove
// breakdown. Header/Footer live in their own .astro components (also ported).
import Layout from '../layouts/Layout.astro';
import { organizationSchema } from '../lib/schema';

// Reused verbatim from ServicesSection.tsx
const services = [
  {
    number: '01',
    title: 'AEO & GEO',
    promise: 'Track and control how you appear in ChatGPT, Claude, and Google AI Overviews.',
    href: '/services/answer-engine-optimization',
  },
  {
    number: '02',
    title: 'PR & Media',
    promise: 'Amplify your narrative and build trust through reputable third-party publications.',
    href: '/services/pr-media',
  },
  {
    number: '03',
    title: 'Executive Authority',
    promise: 'Establish a credible voice through ghostwriting and strategic positioning.',
    href: '/services/executive-authority',
  },
  {
    number: '04',
    title: 'Content<br />Systems',
    promise: 'Build scalable content programs that compound visibility, trust, and demand.',
    href: '/services/content-systems',
  },
];

// Reused verbatim from TestimonialsSection.tsx
const testimonials = [
  {
    quote:
      "We saw a 43% lift in share of voice and 37% improvement in visibility in just two months. Quinn's content and strategic direction have been integral to our growth.",
    name: 'Natasha Zapanta',
    role: 'Lifecycle Marketing & Marketing Ops',
    company: 'Nooks',
  },
  {
    quote:
      'He helped us show up credibly alongside more established companies while the AI visibility landscape was changing quickly.',
    name: 'Brandon Brown',
    role: 'CEO & Co-Founder · Joymore (formerly @ Search Party)',
    company: '',
  },
  {
    quote:
      "He brings a rare and valuable blend of strategic thinking and hands-on execution. I'd jump at the chance to work with him again.",
    name: 'Olivia McNaughten',
    role: 'Director, Product GTM · ShopMy (formerly @ GRIN)',
    company: '',
  },
];

// Reused verbatim from CaseStudiesSection.tsx — including the literal "#"
// hrefs on individual cards, which is what the legacy source itself uses
// (no dedicated case-study detail pages exist yet there either).
const caseStudies = [
  {
    client: 'NOOKS',
    headline: '43% Share of Voice Growth',
    supporting: '+37% Visibility in 60 Days',
    description: 'Increased visibility across AI discovery systems for an AI-native sales platform.',
    href: '#',
  },
  {
    client: 'SEARCH PARTY',
    headline: 'Top 4 Across High-Intent AI Prompts',
    supporting: '3K+ Newsletter Subscribers',
    description: 'Built category authority before launch and earned visibility alongside established AI search leaders.',
    href: '#',
  },
  {
    client: 'GRIN',
    headline: 'One Report. A Quarter of Content.',
    supporting: 'Consumer Research → Content Engine',
    description: 'Turned original consumer research into a narrative platform powering content, earned media, and market positioning.',
    href: '#',
  },
];

// Reused verbatim from client/src/pages/Home.tsx's HOME_FAQ array — this is
// the finalized, live copy (previously this file had older placeholder text).
const faqs = [
  {
    question: 'What does Schwartz Marketing Lab actually do?',
    answer: 'Schwartz Marketing Lab helps B2B companies increase visibility, authority, and demand through AEO/GEO, SEO, executive thought leadership, PR, and scalable content systems. Think of us as a strategic content partner, not a traditional marketing agency.',
  },
  {
    question: 'How is this different from hiring a content agency?',
    answer: "Most content agencies focus on output. We focus on outcomes. Every recommendation, article, campaign, and placement is tied to a business objective — whether that's AI visibility, category authority, pipeline growth, or market positioning.",

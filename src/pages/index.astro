        ))}
      </ul>
    </div>
  </section>

  <!-- ============ CASE STUDIES (dark band) — ported from CaseStudiesSection.tsx ============ -->
  <section id="case-studies" class="bg-foreground" style="padding: 72px clamp(20px, 5vw, 64px) 80px;">
    <div class="max-w-[1100px] mx-auto">
      <div class="flex items-start justify-between mb-10 gap-6">
        <div>
          <p class="font-sans font-bold tracking-[0.28em] uppercase mb-3" style="font-size: 11px; color: hsl(var(--cobalt));">
            Case Studies
          </p>
          <h2 class="font-sans font-black leading-[0.95] tracking-[-0.04em]" style="font-size: clamp(30px, 4vw, 48px); color: hsl(var(--background));">
            Results that hold up.
          </h2>
          <p class="font-serif mt-3 leading-snug" style="font-size: 15px; color: hsl(var(--background) / 0.45); max-width: 360px;">
            Three ways S.LAB turns strategy into measurable growth.
          </p>
        </div>
        <a href="/portfolio" class="case-cta--light hidden md:inline-flex items-center gap-1.5 font-sans font-bold text-[11px] tracking-[0.1em] uppercase shrink-0 mt-1 transition-colors" style="color: hsl(var(--background) / 0.3);">
          View all work
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {caseStudies.map((study) => (
          <div class="flex flex-col bg-background" style="padding: 28px 26px 24px;">
            <p class="font-sans font-black leading-none tracking-[-0.02em] text-foreground mb-5" style="font-size: 13px;">{study.client}</p>
            <div class="mb-5" style="border-top: 1px solid hsl(var(--foreground) / 0.08);"></div>
            <p class="font-sans font-black leading-[1.02] tracking-[-0.035em] text-foreground mb-3" style="font-size: clamp(30px, 3.8vw, 46px);">{study.headline}</p>
            <p class="font-sans font-bold tracking-[0.18em] uppercase mb-5" style="font-size: 10px; color: hsl(var(--cobalt));">{study.supporting}</p>
            <div class="mb-4" style="border-top: 1px solid hsl(var(--foreground) / 0.08);"></div>
            <p class="font-serif leading-[1.6] flex-1 mb-6" style="font-size: 14px; color: hsl(var(--foreground) / 0.58);">{study.description}</p>
            <a href={study.href} class="case-cta--dark inline-flex items-center gap-1.5 font-sans font-bold tracking-[0.1em] uppercase transition-colors" style="font-size: 10px; color: hsl(var(--foreground) / 0.35);">
              View case study
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </a>
          </div>
        ))}
      </div>

      <div class="mt-8 md:hidden">
        <a href="/portfolio" class="inline-flex items-center gap-1.5 font-sans font-bold text-[11px] tracking-[0.1em] uppercase" style="color: hsl(var(--background) / 0.4);">
          View all work
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ FAQ — ported from FaqSection.tsx ============ -->
  <section class="py-24 border-t border-foreground/10">
    <div class="px-6 sm:px-10 md:px-14 lg:px-20 max-w-[1100px] mx-auto">
      <div class="mb-12">
        <p class="font-sans text-xs font-semibold tracking-[0.22em] uppercase text-foreground/50 mb-3">FAQ</p>
        <h2 class="font-sans font-black text-[28px] md:text-[36px] leading-[1.05] tracking-tight text-foreground">Common questions.</h2>
      </div>

      <div class="divide-y divide-foreground/10">
        {faqs.map((f) => (
          <details class="faq-item group">
            <summary class="w-full flex items-center justify-between gap-6 py-6 cursor-pointer list-none">
              <span class="font-sans font-semibold text-base md:text-lg text-foreground transition-colors group-hover:text-foreground/80">{f.question}</span>
              <span class="faq-item__icon flex-shrink-0 w-6 h-6 flex items-center justify-center" style="color: hsl(var(--cobalt));" aria-hidden="true"></span>
            </summary>
            <div class="faq-item__content">
              <p class="font-serif text-base text-foreground/70 leading-relaxed pb-6 max-w-2xl">{f.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Rewrite for Astro: legacy Hero.tsx cycles WORDS via React state + setInterval.
  // Same DOM result here via plain JS, gated on prefers-reduced-motion exactly
  // as the legacy `useReducedMotion()` check does.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const wordEls = Array.from(document.querySelectorAll('[data-rotating-words] [data-word]'));
    let index = 0;
    if (wordEls.length > 1) {
      setInterval(() => {
        const current = wordEls[index];
        current.style.opacity = '0';
        current.style.transform = 'translateY(-8px)';
        const next = (index + 1) % wordEls.length;
        wordEls[next].style.transform = 'translateY(10px)';
        setTimeout(() => {
          wordEls[next].style.opacity = '1';
          wordEls[next].style.transform = 'translateY(0)';
        }, 30);
        index = next;
      }, 2000);
    }
  }

  // FAQ open/close animation — legacy used framer-motion's AnimatePresence to
  // animate height 0 -> auto on the answer wrapper. Native <details>/<summary>
  // has no animatable height by default (the browser just shows/hides the
  // content in one frame), so this progressively enhances the same markup:
  // the <details>/<summary>/<p> structure stays exactly as rendered — nothing
  // is removed from the DOM and no content is hidden behind JS — this script
  // only smooths the existing open/close transition with an inline height
  // animation. With JS disabled, or for a crawler that doesn't run it, the
  // native <details> behavior (instant show/hide, content always present in
  // the DOM) works exactly as before.
  document.querySelectorAll('.faq-item').forEach((item) => {
    const content = item.querySelector('.faq-item__content');
    if (!content) return;
    const summary = item.querySelector('summary');
    if (!summary) return;
    let animating = false;

    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (animating) return;

      if (item.hasAttribute('open')) {
        // Closing: animate from current height down to 0, then remove [open].
        animating = true;
        const startHeight = content.scrollHeight;
        content.style.height = startHeight + 'px';
        // Double rAF: a single rAF can get batched with this style write into
        // the same frame (no committed "start" frame for the browser to
        // transition from), which silently no-ops the animation. Two rAFs
        // guarantee a paint has happened with `startHeight` applied before we
        // change the target value.
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            content.style.height = '0px';
          });
        });
        content.addEventListener('transitionend', function onEnd() {
          content.removeEventListener('transitionend', onEnd);
          item.removeAttribute('open');
          content.style.height = '';
          animating = false;
        }, { once: true });
      } else {
        // Opening: set [open] so content renders, animate from 0 to its
        // natural height, then clear the inline height so it stays fluid.
        animating = true;
        item.setAttribute('open', '');
        content.style.height = '0px';
        // Re-measure scrollHeight inside the (double) rAF rather than
        // immediately after setAttribute: measuring too early can capture a
        // height based on not-yet-loaded web font metrics (FOUT), locking in
        // a fixed pixel value that's too short once the real font swaps in
        // and the answer text re-wraps. Measuring right before the animated
        // write keeps it accurate, and double rAF ensures the 0px start
        // value is committed before the transition target is applied.
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const targetHeight = content.scrollHeight;
            content.style.height = targetHeight + 'px';
          });
        });
        content.addEventListener('transitionend', function onEnd() {
          content.removeEventListener('transitionend', onEnd);
          content.style.height = '';
          animating = false;
        }, { once: true });
      }
    });
  });
</script>

<style>
  /* Values Tailwind's JIT class list can't express as utilities directly are
     kept here — same approach the legacy code uses (className for layout,
     small CSS rules for the plus/minus icon, hover color swaps that need a
     CSS variable target, etc). Everything else lives as literal Tailwind
     classes above. */

  .service-row__arrow {
    /* legacy: group-hover:text-[hsl(var(--cobalt))] */
  }
  .service-row:hover .service-row__arrow,
  .service-row:focus-visible .service-row__arrow {
    color: hsl(var(--cobalt));
  }

  .case-cta--light:hover {
    color: hsl(var(--background) / 0.75);
  }
  .case-cta--dark:hover {
    color: hsl(var(--foreground));
  }

  /* FAQ plus/minus icon — ported behavior from FaqSection.tsx's Plus/Minus
     lucide-react swap, drawn in CSS since lucide isn't installed in Astro. */
  .faq-item__icon::before,
  .faq-item__icon::after {
    content: '';
    position: relative;
    display: block;
    background: currentColor;
  }
  .faq-item__icon::before {
    width: 14px;
    height: 2px;
  }
  .faq-item__icon::after {
    width: 2px;
    height: 14px;
    position: absolute;
    transition: transform 0.2s ease;
  }
  .faq-item[open] .faq-item__icon::after {
    transform: rotate(90deg) scale(0);
  }

  /* FAQ answer height animation — matches the legacy 0.25s easeInOut timing
     used by framer-motion's AnimatePresence transition. The JS in the
     <script> block sets an explicit inline height before/after toggling
     [open] so this transition has a concrete value to animate between. */
  .faq-item__content {
    overflow: hidden;
    height: 0;
    transition: height 0.25s ease-in-out;
  }
  .faq-item[open] .faq-item__content {
    height: auto;
  }

  /* Print fallback for the rotating hero word — ported verbatim from the
     legacy @media print rule in index.css. */
  @media print {
    [data-rotating-words] [data-word] {
      opacity: 0 !important;

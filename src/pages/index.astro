  <!-- ============ SERVICES — ported from ServicesSection.tsx ============ -->
  <section id="focus" class="relative bg-background text-foreground py-24 md:py-32">
    <div class="container mx-auto px-4 md:px-6 max-w-6xl">
      <div class="mb-16 md:mb-20 max-w-3xl">

---
// Homepage — ported directly from the legacy Replit repo's component tree:
//   client/src/pages/Home.tsx (section order, FAQ copy, document title)
//   client/src/components/Hero.tsx
//   client/src/components/TestimonialsSection.tsx
//   client/src/components/ServicesSection.tsx
//   client/src/components/CaseStudiesSection.tsx
//   client/src/components/FaqSection.tsx
// See the migration write-up for the full per-section reuse/port/rewrite/remove
// breakdown. Header/Footer live in their own .astro components (also ported).
import Layout from '../layouts/Layout.astro';
import { organizationSchema } from '../lib/schema';
import { getEntry } from 'astro:content';

const seo = await getEntry('seo', 'home');
if (!seo) throw new Error('Missing seo/home.yaml entry');

// Reused verbatim from ServicesSection.tsx
const services = [
  {
    number: '01',
    title: 'AEO & GEO',
    promise: 'Track and control how you appear in ChatGPT, Claude, and Google AI Overviews.',
    href: '/services/answer-engine-optimization',
  },
  {
    number: '02',
    title: 'PR & Media',
    promise: 'Amplify your narrative and build trust through reputable third-party publications.',
    href: '/services/pr-media',
  },
  {
    number: '03',
    title: 'Executive Authority',
    promise: 'Establish a credible voice through ghostwriting and strategic positioning.',
    href: '/services/executive-authority',
  },
  {
    number: '04',
    title: 'Content<br />Systems',
    promise: 'Build scalable content programs that compound visibility, trust, and demand.',
    href: '/services/content-systems',
  },
];

// Reused verbatim from TestimonialsSection.tsx
const testimonials = [
  {
    quote:
      "We saw a 43% lift in share of voice and 37% improvement in visibility in just two months. Quinn's content and strategic direction have been integral to our growth.",
    name: 'Natasha Zapanta',
    role: 'Lifecycle Marketing & Marketing Ops',
    company: 'Nooks',
  },
  {
    quote:
      'He helped us show up credibly alongside more established companies while the AI visibility landscape was changing quickly.',
    name: 'Brandon Brown',
    role: 'CEO & Co-Founder · Joymore (formerly @ Search Party)',
    company: '',
  },
  {
    quote:
      "He brings a rare and valuable blend of strategic thinking and hands-on execution. I'd jump at the chance to work with him again.",
    name: 'Olivia McNaughten',
    role: 'Director, Product GTM · ShopMy (formerly @ GRIN)',
    company: '',
  },
];

// Dedicated case-study detail pages now exist for all three (case-studies/
// nooks-aeo, search-party-aeo, grin-content-systems) — linked here instead
// of the legacy site's literal "#" placeholders.
const caseStudies = [
  {
    client: 'NOOKS',
    headline: '43% Share of Voice Growth',
    supporting: '+37% Visibility in 60 Days',
    description: 'Increased visibility across AI discovery systems for an AI-native sales platform.',
    href: '/case-studies/nooks-aeo',
  },
  {
    client: 'SEARCH PARTY',
    headline: 'Top 4 Across High-Intent AI Prompts',
    supporting: '3K+ Newsletter Subscribers',
    description: 'Built category authority before launch and earned visibility alongside established AI search leaders.',
    href: '/case-studies/search-party-aeo',
  },
  {
    client: 'GRIN',
    headline: 'One Report. A Quarter of Content.',
    supporting: 'Consumer Research → Content Engine',
    description: 'Turned original consumer research into a narrative platform powering content, earned media, and market positioning.',
    href: '/case-studies/grin-content-systems',
  },
];

// Reused verbatim from client/src/pages/Home.tsx's HOME_FAQ array — this is
// the finalized, live copy (previously this file had older placeholder text).
const faqs = [
  {
    question: 'What does Schwartz Marketing Lab actually do?',
    answer: 'Schwartz Marketing Lab helps B2B companies increase visibility, authority, and demand through AEO/GEO, SEO, executive thought leadership, PR, and scalable content systems. Think of us as a strategic content partner, not a traditional marketing agency.',
  },
  {
    question: 'How is this different from hiring a content agency?',
    answer: "Most content agencies focus on output. We focus on outcomes. Every recommendation, article, campaign, and placement is tied to a business objective — whether that's AI visibility, category authority, pipeline growth, or market positioning.",
  },
  {
    question: 'Do you work with early-stage companies or only established brands?',
    answer: "Both. The work looks different at each stage, but the approach is the same: understand the business goal, build a system, execute well. We've worked with funded startups and growth-stage B2B companies alike.",
  },
  {
    question: 'What is AEO/GEO and why does it matter?',
    answer: 'Answer Engine Optimization (AEO) and Generative Engine Optimization (GEO) help companies appear in AI-generated answers from ChatGPT, Claude, Perplexity, and Google AI Overviews. As more buyers rely on AI systems for research and recommendations, visibility in these environments is becoming as important as traditional search rankings. <a href="/services/answer-engine-optimization" class="inline-link">Answer engine optimization</a> is one of our core service areas.',
  },
  {
    question: 'What does a typical engagement look like?',
    answer: 'It starts with a discovery conversation and audit. From there, we build a roadmap and move into execution — content production, optimization, and reporting on a regular cadence. Depending on the engagement, that may include strategy, research, content production, executive thought leadership, AI visibility initiatives, or distribution.',
  },
  {
    question: 'Do you offer one-off projects or only retainers?',
    answer: 'Both. Audits, strategy documents, and specific content deliverables are available as standalone projects. Retainers are for clients who want continuous execution and momentum.',
  },
];

const words = ['AEO.', 'GEO.', 'SEO.', 'content.'];
---

<Layout
  title={seo.data.title}
  description={seo.data.description}
  canonicalPath="/"
  schema={organizationSchema()}
>
  <!-- ============ HERO — ported from Hero.tsx ============ -->
  <section id="hero" class="relative bg-background text-foreground">
    <div
      class="relative mx-3 sm:mx-5 md:mx-8 mt-2 md:mt-6 mb-10 md:mb-14 border-t border-l border-r border-foreground/70 px-6 sm:px-10 md:px-14 lg:px-20 flex flex-col justify-center"
      style="min-height: calc(100vh - 9rem);"
    >
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(60% 55% at 35% 38%, rgba(20,20,20,0.045) 0%, rgba(20,20,20,0) 70%);"
      ></div>

      <div class="flex flex-col py-12 md:py-16">
        <h1
          class="font-sans font-black text-foreground text-[52px] sm:text-[72px] md:text-[96px] lg:text-[124px] xl:text-[144px] leading-[0.95] tracking-[-0.045em] m-0"
          aria-label="Drive revenue through AEO."
        >
          Drive revenue<br />
          <span class="inline-flex items-baseline gap-[0.18em]">
            through
            <span class="inline-grid" style="color: hsl(var(--cobalt));" data-rotating-words>
              <span style="grid-area: 1/1; visibility: hidden;" aria-hidden="true">content.</span>
              <span style="grid-area: 1/1;">AEO.</span>
              {words.map((word, i) => (
                <span
                  aria-hidden="true"
                  data-word={i}
                  style={`grid-area: 1/1; background: hsl(var(--background)); opacity: ${i === 0 ? 1 : 0}; transform: translateY(${i === 0 ? '0' : '10px'});`}
                  class="transition-[opacity,transform] duration-300"
                >{word}</span>
              ))}
            </span>
          </span>
        </h1>

        <div class="mt-10 md:mt-12 flex flex-col gap-8 md:gap-10">
          <p class="font-serif text-foreground text-base md:text-lg lg:text-[19px] leading-[1.55] max-w-md">
            Traditional B2B marketing agencies are stuck in the past. We build brand awareness and
            drive sales with modern solutions for AEO, SEO, and content marketing.
          </p>
          <div class="flex-shrink-0">
            <a
              href="/contact"
              class="inline-flex items-center gap-2 text-base font-sans font-semibold rounded-none border-2 border-foreground bg-foreground text-background px-7 py-3.5 transition-colors hover:bg-background hover:text-foreground"
            >
              Find out how
              <svg class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="absolute left-0 right-0 bottom-0 flex items-center translate-y-1/2 overflow-hidden">
        <div class="h-px bg-foreground/70 w-10 sm:w-14 md:w-20 lg:w-28 shrink-0"></div>
        <div class="font-sans text-[11px] sm:text-[13px] font-semibold tracking-[0.24em] sm:tracking-[0.28em] uppercase text-foreground px-3 sm:px-5 leading-none whitespace-nowrap">
          Schwartz Marketing Lab
        </div>
        <div class="h-px bg-foreground/70 flex-1 min-w-[16px]"></div>
        <div class="font-sans text-[11px] sm:text-[13px] font-semibold tracking-[0.24em] sm:tracking-[0.28em] uppercase text-foreground px-3 sm:px-5 leading-none whitespace-nowrap">
          AEO · SEO · Content
        </div>
        <div class="h-px bg-foreground/70 w-10 sm:w-14 md:w-20 lg:w-28 shrink-0"></div>
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS — ported from TestimonialsSection.tsx ============ -->
  <section id="testimonials" class="relative bg-background text-foreground py-24 md:py-32">
    <div class="container mx-auto px-4 md:px-6 max-w-6xl">
      <div class="mb-24 md:mb-28 max-w-3xl">
        <div class="font-sans text-[13px] font-semibold tracking-[0.28em] uppercase text-foreground mb-6">
          What clients say
        </div>
        <h2 class="font-sans font-black text-foreground text-[40px] sm:text-[56px] md:text-[72px] lg:text-[88px] leading-[0.95] tracking-[-0.04em] m-0">
          Proof, not <span style="color: hsl(var(--cobalt));">promises</span>.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 lg:gap-12 border-t border-foreground/[0.08] pt-14 md:pt-16">
        {testimonials.map((t) => (
          <figure class="flex flex-col">
            <div aria-hidden="true" class="font-sans font-black text-[52px] md:text-[62px] leading-[0.7] mb-4" style="color: hsl(var(--cobalt) / 0.45);">
              &ldquo;
            </div>
            <blockquote class="font-serif text-[17px] md:text-[18px] leading-[1.55] text-foreground mb-6">
              {t.quote}
            </blockquote>
            <figcaption class="mt-auto pt-4 border-t border-foreground/85">
              <div class="font-sans text-[12px] font-semibold tracking-[0.24em] uppercase text-foreground">{t.name}</div>
              <div class="font-sans text-[12px] font-medium tracking-[0.18em] uppercase text-foreground/65 mt-1">
                {t.role ? `${t.role}${t.company ? ` · ${t.company}` : ''}` : t.company}
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SERVICES — ported from ServicesSection.tsx ============ -->
  <section id="focus" class="relative bg-background text-foreground py-24 md:py-32">
    <div class="container mx-auto px-4 md:px-6 max-w-6xl">
      <div class="mb-16 md:mb-20 max-w-3xl">
        <div class="font-sans text-[13px] font-semibold tracking-[0.28em] uppercase text-foreground mb-6">
          What we do
        </div>
        <h2 class="font-sans font-black text-foreground text-[40px] sm:text-[56px] md:text-[72px] lg:text-[88px] leading-[0.95] tracking-[-0.04em] m-0">
          How brands get <span style="color: hsl(var(--cobalt));">discovered</span>.
        </h2>
      </div>

      <ul class="border-t border-foreground/85">
        {services.map((s) => (
          <li class="border-b border-foreground/85">
            <a href={s.href} class="service-row group block relative outline-none focus-visible:outline-none">
              <span
                aria-hidden="true"
                class="pointer-events-none absolute left-0 top-0 bottom-0 w-[3px] origin-top scale-y-0 group-hover:scale-y-100 group-focus-visible:scale-y-100 transition-transform duration-300 ease-out"
                style="background-color: hsl(var(--cobalt));"
              ></span>
              <div class="grid grid-cols-12 gap-4 md:gap-6 items-center py-8 md:py-10 px-3 md:px-5 transition-colors duration-300 group-hover:bg-foreground/[0.03] group-focus-visible:bg-foreground/[0.05] group-focus-visible:ring-2 group-focus-visible:ring-[hsl(var(--cobalt))] group-focus-visible:ring-inset">
                <div class="col-span-2 md:col-span-1">
                  <span class="font-sans text-[13px] md:text-[14px] font-semibold tracking-[0.2em] uppercase text-foreground/55">{s.number}</span>
                </div>
                <div class="col-span-10 md:col-span-5">
                  <h3
                    class="font-sans font-black text-foreground text-[28px] sm:text-[36px] md:text-[44px] lg:text-[52px] leading-[1] tracking-[-0.025em] m-0 min-h-[2em] flex items-center"
                    set:html={s.title}
                  />
                </div>
                <div class="col-span-12 md:col-span-5 mt-3 md:mt-0">
                  <p class="font-serif text-[16px] md:text-[17px] leading-[1.5] text-foreground/80 m-0">{s.promise}</p>
                </div>
                <div class="hidden md:flex col-span-1 justify-end">
                  <svg
                    class="service-row__arrow w-7 h-7 text-foreground transition-all duration-300 ease-out group-hover:translate-x-1 group-hover:-translate-y-1 group-focus-visible:translate-x-1 group-focus-visible:-translate-y-1"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                  ><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ============ CASE STUDIES (dark band) — ported from CaseStudiesSection.tsx ============ -->
  <section id="case-studies" class="bg-foreground" style="padding: 72px clamp(20px, 5vw, 64px) 80px;">
    <div class="max-w-[1100px] mx-auto">
      <div class="flex items-start justify-between mb-10 gap-6">
        <div>
          <p class="font-sans font-bold tracking-[0.28em] uppercase mb-3" style="font-size: 11px; color: hsl(var(--cobalt));">
            Case Studies
          </p>
          <h2 class="font-sans font-black leading-[0.95] tracking-[-0.04em]" style="font-size: clamp(30px, 4vw, 48px); color: hsl(var(--background));">
            Results that hold up.
          </h2>
          <p class="font-serif mt-3 leading-snug" style="font-size: 15px; color: hsl(var(--background) / 0.45); max-width: 360px;">
            Three ways S.LAB turns strategy into measurable growth.
          </p>
        </div>
        <a href="/case-studies" class="case-cta--light hidden md:inline-flex items-center gap-1.5 font-sans font-bold text-[11px] tracking-[0.1em] uppercase shrink-0 mt-1 transition-colors" style="color: hsl(var(--background) / 0.3);">
          View all work
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {caseStudies.map((study) => (
          <div class="flex flex-col bg-background" style="padding: 28px 26px 24px;">
            <p class="font-sans font-black leading-none tracking-[-0.02em] text-foreground mb-5" style="font-size: 13px;">{study.client}</p>
            <div class="mb-5" style="border-top: 1px solid hsl(var(--foreground) / 0.08);"></div>
            <p class="font-sans font-black leading-[1.02] tracking-[-0.035em] text-foreground mb-3" style="font-size: clamp(30px, 3.8vw, 46px);">{study.headline}</p>
            <p class="font-sans font-bold tracking-[0.18em] uppercase mb-5" style="font-size: 10px; color: hsl(var(--cobalt));">{study.supporting}</p>
            <div class="mb-4" style="border-top: 1px solid hsl(var(--foreground) / 0.08);"></div>
            <p class="font-serif leading-[1.6] flex-1 mb-6" style="font-size: 14px; color: hsl(var(--foreground) / 0.58);">{study.description}</p>
            <a href={study.href} class="case-cta--dark inline-flex items-center gap-1.5 font-sans font-bold tracking-[0.1em] uppercase transition-colors" style="font-size: 10px; color: hsl(var(--foreground) / 0.35);">
              View case study
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </a>
          </div>
        ))}
      </div>

      <div class="mt-8 md:hidden">
        <a href="/case-studies" class="inline-flex items-center gap-1.5 font-sans font-bold text-[11px] tracking-[0.1em] uppercase" style="color: hsl(var(--background) / 0.4);">
          View all work
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ FAQ — ported from FaqSection.tsx ============ -->
  <section class="py-24 border-t border-foreground/10">
    <div class="px-6 sm:px-10 md:px-14 lg:px-20 max-w-[1100px] mx-auto">
      <div class="mb-12">
        <p class="font-sans text-xs font-semibold tracking-[0.22em] uppercase text-foreground/50 mb-3">FAQ</p>
        <h2 class="font-sans font-black text-[28px] md:text-[36px] leading-[1.05] tracking-tight text-foreground">Common questions.</h2>
      </div>

      <div class="divide-y divide-foreground/10">
        {faqs.map((f) => (
          <div class="faq-item py-6">
            <h3 class="font-sans font-semibold text-base md:text-lg text-foreground m-0">{f.question}</h3>
            <p class="font-serif text-base text-foreground/70 leading-relaxed pt-3 max-w-2xl" set:html={f.answer} />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  // Rewrite for Astro: legacy Hero.tsx cycles WORDS via React state + setInterval.
  // Same DOM result here via plain JS, gated on prefers-reduced-motion exactly
  // as the legacy `useReducedMotion()` check does.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduceMotion) {
    const wordEls = Array.from(document.querySelectorAll('[data-rotating-words] [data-word]'));
    let index = 0;
    if (wordEls.length > 1) {
      setInterval(() => {
        const current = wordEls[index];
        current.style.opacity = '0';
        current.style.transform = 'translateY(-8px)';
        const next = (index + 1) % wordEls.length;
        wordEls[next].style.transform = 'translateY(10px)';
        setTimeout(() => {
          wordEls[next].style.opacity = '1';
          wordEls[next].style.transform = 'translateY(0)';
        }, 30);
        index = next;
      }, 2000);
    }
  }

</script>

<style>
  /* Values Tailwind's JIT class list can't express as utilities directly are
     kept here — same approach the legacy code uses (className for layout,
     small CSS rules for the plus/minus icon, hover color swaps that need a
     CSS variable target, etc). Everything else lives as literal Tailwind
     classes above. */

  .service-row__arrow {
    /* legacy: group-hover:text-[hsl(var(--cobalt))] */
  }
  .service-row:hover .service-row__arrow,
  .service-row:focus-visible .service-row__arrow {
    color: hsl(var(--cobalt));
  }

  .case-cta--light:hover {
    color: hsl(var(--background) / 0.75);
  }
  .case-cta--dark:hover {
    color: hsl(var(--foreground));
  }

  /* Print fallback for the rotating hero word — ported verbatim from the
     legacy @media print rule in index.css. */
  @media print {
    [data-rotating-words] [data-word] {
      opacity: 0 !important;
    }
  }
</style>

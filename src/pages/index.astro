---
import Layout from '../layouts/Layout.astro';
import { organizationSchema } from '../lib/schema';

const services = [
  {
    number: '01',
    title: 'AEO & GEO',
    description: 'Track and control how you appear in ChatGPT, Claude, and Google AI Overviews.',
    href: '/services/answer-engine-optimization',
  },
  {
    number: '02',
    title: 'PR & Media',
    description: 'Amplify your narrative and build trust through reputable third-party publications.',
    href: '/services/pr-media',
  },
  {
    number: '03',
    title: 'Executive Authority',
    description: 'Establish a credible voice through ghostwriting and strategic positioning.',
    href: '/services/executive-authority',
  },
  {
    number: '04',
    title: 'Content Systems',
    description: 'Build scalable content programs that compound visibility, trust, and demand.',
    href: '/services/content-systems',
  },
];

const testimonials = [
  {
    quote:
      "We saw a 43% lift in share of voice and 37% improvement in visibility in just two months. Quinn's content and strategic direction have been integral to our growth.",
    name: 'Natasha Zapanta',
    title: 'Lifecycle Marketing & Marketing Ops · Nooks',
  },
  {
    quote:
      'He helped us show up credibly alongside more established companies while the AI visibility landscape was changing quickly.',
    name: 'Brandon Brown',
    title: 'CEO & Co-Founder · Joymore (formerly @ Search Party)',
  },
  {
    quote:
      "He brings a rare and valuable blend of strategic thinking and hands-on execution. I'd jump at the chance to work with him again.",
    name: 'Olivia McNaughten',
    title: 'Director, Product GTM · ShopMy (formerly @ Grin)',
  },
];

const caseStudies = [
  {
    client: 'Nooks',
    headline: '43% Share of Voice Growth',
    stat: '+37% visibility in 60 days',
    description: 'Increased visibility across AI discovery systems for an AI-native sales platform.',
  },
  {
    client: 'Search Party',
    headline: 'Top 4 Across High-Intent AI Prompts',
    stat: '3K+ newsletter subscribers',
    description: 'Built category authority before launch and earned visibility alongside established AI search leaders.',
  },
  {
    client: 'Grin',
    headline: 'One Report. A Quarter of Content.',
    stat: 'Consumer research → content engine',
    description: 'Turned original consumer research into a narrative platform powering content, earned media, and market positioning.',
  },
];

const faqs = [
  { question: 'What does Schwartz Marketing Lab actually do?', answer: 'We help B2B brands get found across traditional search and AI discovery systems through AEO, SEO, content strategy, and authority building.' },
  { question: 'How is this different from hiring a content agency?', answer: 'We combine SEO, AEO, GEO, and authority building into one discoverability system rather than producing content in isolation from how it gets found.' },
  { question: 'Do you work with early-stage companies or only established brands?', answer: 'Both — engagements are scoped to where a company is in building authority and visibility, not company size alone.' },
  { question: 'What is AEO/GEO and why does it matter?', answer: 'AEO (answer engine optimization) and GEO (generative engine optimization) are the practices of making your brand discoverable and citable inside AI tools like ChatGPT, Claude, and Google AI Overviews — channels traditional SEO alone doesn’t cover.' },
  { question: 'What does a typical engagement look like?', answer: 'Every engagement starts with strategy: an audit of current visibility, a positioning review, and a plan aligned to your specific growth goals.' },
  { question: 'Do you offer one-off projects or only retainers?', answer: 'Both, depending on the goal — some work is project-based, some is an ongoing growth partnership.' },
];
---

<Layout
  title="AEO Agency & Content Strategy | Schwartz Marketing Lab"
  description="Schwartz Marketing Lab helps B2B brands get found in AI search, Google, and modern discovery — through AEO, SEO, content strategy, and authority building."
  canonicalPath="/"
  schema={organizationSchema()}
>
  <section class="hero">
    <div class="hero__frame">
      <h1>Drive revenue<br />through <span class="hero__accent">AEO.</span></h1>
      <p class="hero__sub">
        Traditional B2B marketing agencies are stuck in the past. We build brand awareness and
        drive sales with modern solutions for AEO, SEO, and content marketing.
      </p>
      <a href="/contact" class="button">Find out how →</a>
      <div class="hero__rule">
        <span class="hero__rule-line"></span>
        <span class="hero__rule-label">Schwartz Marketing Lab</span>
        <span class="hero__rule-line hero__rule-line--grow"></span>
        <span class="hero__rule-label">AEO · SEO · Content</span>
        <span class="hero__rule-line"></span>
      </div>
    </div>
  </section>

  <section class="testimonials wrapper">
    <p class="eyebrow">What clients say</p>
    <h2>Proof, not <span class="text-accent">promises</span>.</h2>
    <div class="testimonials__grid">
      {testimonials.map((t) => (
        <figure class="testimonial">
          <div class="testimonial__mark" aria-hidden="true">&ldquo;</div>
          <blockquote>{t.quote}</blockquote>
          <figcaption>
            <span class="testimonial__name">{t.name}</span>
            <span class="testimonial__title">{t.title}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section id="focus" class="services wrapper">
    <p class="eyebrow">What I do</p>
    <h2>Four ways to get <span class="text-accent">found</span>.</h2>
    <ul class="services__list">
      {services.map((s) => (
        <li class="service-row">
          <a class="service-row__link" href={s.href}>
            <span class="service-row__number">{s.number}</span>
            <h3 class="service-row__title">{s.title}</h3>
            <p class="service-row__promise">{s.description}</p>
            <span class="service-row__arrow" aria-hidden="true">↗</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="case-studies">
    <div class="wrapper case-studies__inner">
      <div class="case-studies__header">
        <div>
          <p class="eyebrow eyebrow--on-dark">Case studies</p>
          <h2 class="case-studies__heading">Results that hold up.</h2>
          <p class="case-studies__sub">Three ways S.LAB turns strategy into measurable growth.</p>
        </div>
        <a href="/portfolio" class="case-studies__view-all">View all work ↗</a>
      </div>
      <div class="case-studies__grid">
        {caseStudies.map((c) => (
          <article class="case-study">
            <p class="case-study__client">{c.client}</p>
            <div class="case-study__rule"></div>
            <p class="case-study__headline">{c.headline}</p>
            <p class="case-study__stat">{c.stat}</p>
            <div class="case-study__rule"></div>
            <p class="case-study__description">{c.description}</p>
            <span class="case-study__cta">View case study ↗</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="faq wrapper">
    <p class="eyebrow">FAQ</p>
    <h2>Common questions.</h2>
    <div class="faq__list">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary>{f.question}<span class="faq__icon" aria-hidden="true"></span></summary>
          <p>{f.answer}</p>
        </details>
      ))}
    </div>
  </section>
</Layout>

<style>
  section {
    padding: 64px 24px;
  }

  .text-accent {
    color: var(--color-accent);
  }

  /* ---------- Hero ---------- */

  .hero {
    padding: 0 24px;
  }

  .hero__frame {
    max-width: var(--content-max-width);
    margin: 0 auto;
    border-top: var(--border-frame);
    border-left: var(--border-frame);
    border-right: var(--border-frame);
    padding: clamp(48px, 9vw, 96px) clamp(24px, 5vw, 56px) 0;
    position: relative;
  }

  .hero h1 {
    font-size: clamp(40px, 8vw, 112px);
    letter-spacing: -0.01em;
  }

  .hero__accent {
    color: var(--color-accent);
  }

  .hero__sub {
    max-width: 640px;
    margin: 28px 0 36px;
    font-size: 18px;
    color: var(--color-text-muted);
  }

  .hero__rule {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px 0;
    margin-top: 56px;
    border-top: var(--border-hairline);
  }

  .hero__rule-line {
    height: 1px;
    width: 32px;
    background: rgba(23, 23, 23, 0.3);
  }

  .hero__rule-line--grow {
    flex: 1;
  }

  .hero__rule-label {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .hero__rule {
      flex-wrap: wrap;
    }
    .hero__rule-line--grow {
      display: none;
    }
  }

  /* ---------- Eyebrow ---------- */

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0 0 12px;
  }

  .eyebrow--on-dark {
    color: rgba(244, 241, 231, 0.55);
  }

  /* ---------- Testimonials ---------- */

  .testimonials h2 {
    font-size: clamp(32px, 6vw, 64px);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0;
    margin-top: 40px;
    border-top: var(--border-hairline);
  }

  .testimonial {
    padding: 32px 28px 0;
    margin: 0;
    border-right: var(--border-hairline);
  }

  .testimonial:last-child {
    border-right: none;
  }

  .testimonial__mark {
    font-family: var(--font-heading);
    font-size: 56px;
    line-height: 1;
    color: var(--color-accent);
    margin-bottom: 8px;
  }

  .testimonial blockquote {
    margin: 0 0 24px;
    font-style: italic;
    font-size: 17px;
    line-height: 1.5;
  }

  .testimonial figcaption {
    border-top: 1px solid rgba(23, 23, 23, 0.85);
    padding-top: 14px;
    padding-bottom: 28px;
  }

  .testimonial__name {
    display: block;
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .testimonial__title {
    display: block;
    font-size: 12px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-top: 4px;
  }

  /* ---------- Services ---------- */

  .services h2 {
    font-size: clamp(32px, 6vw, 64px);
  }

  .services__list {
    list-style: none;
    margin: 40px 0 0;
    padding: 0;
    border-top: 1px solid rgba(23, 23, 23, 0.85);
  }

  .service-row {
    border-bottom: 1px solid rgba(23, 23, 23, 0.85);
    position: relative;
  }

  .service-row__link {
    display: grid;
    grid-template-columns: 48px 1fr 1fr 32px;
    align-items: center;
    gap: 24px;
    padding: 28px 0;
    position: relative;
    padding-left: 16px;
  }

  .service-row__link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--color-accent);
    transform: scaleY(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .service-row__link:hover::before {
    transform: scaleY(1);
  }

  .service-row__number {
    font-family: var(--font-heading);
    font-weight: 900;
    color: var(--color-text-muted);
    font-size: 14px;
  }

  .service-row__title {
    margin: 0;
    font-size: 22px;
  }

  .service-row__promise {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 15px;
  }

  .service-row__arrow {
    justify-self: end;
    font-size: 20px;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .service-row__link:hover .service-row__arrow {
    transform: translate(4px, -4px);
    color: var(--color-accent);
  }

  @media (max-width: 760px) {
    .service-row__link {
      grid-template-columns: 32px 1fr 32px;
    }
    .service-row__promise {
      display: none;
    }
  }

  /* ---------- Case studies (dark band) ---------- */

  .case-studies {
    background: var(--color-text);
    color: var(--color-bg);
    padding: 72px 0 80px;
  }

  .case-studies__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 24px;
  }

  .case-studies__heading {
    color: var(--color-bg);
    font-size: clamp(32px, 6vw, 64px);
    margin: 0 0 12px;
  }

  .case-studies__sub {
    max-width: 480px;
    color: rgba(244, 241, 231, 0.65);
    margin: 0;
  }

  .case-studies__view-all {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-bg);
    white-space: nowrap;
    border-bottom: 1px solid rgba(244, 241, 231, 0.4);
    padding-bottom: 4px;
  }

  .case-studies__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }

  .case-study {
    background: var(--color-bg);
    color: var(--color-text);
    padding: 32px 28px;
    margin: 0;
  }

  .case-study__client {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0 0 16px;
  }

  .case-study__rule {
    border-top: var(--border-hairline);
    margin: 16px 0;
  }

  .case-study__headline {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: clamp(24px, 3.2vw, 36px);
    line-height: 1.1;
    margin: 0 0 12px;
  }

  .case-study__stat {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 13px;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    margin: 0;
  }

  .case-study__description {
    margin: 0;
    color: var(--color-text-muted);
  }

  .case-study__cta {
    display: inline-block;
    margin-top: 20px;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  /* ---------- FAQ ---------- */

  .faq h2 {
    font-size: clamp(32px, 6vw, 64px);
  }

  .faq__list {
    margin-top: 32px;
    border-top: 1px solid rgba(23, 23, 23, 0.1);
  }

  .faq__item {
    border-bottom: 1px solid rgba(23, 23, 23, 0.1);
    padding: 22px 0;
  }

  .faq__item summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 18px;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq__item summary::-webkit-details-marker {
    display: none;
  }

  .faq__icon {
    position: relative;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-left: 16px;
  }

  .faq__icon::before,
  .faq__icon::after {
    content: '';
    position: absolute;
    background: var(--color-accent);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .faq__icon::before {
    width: 14px;
    height: 2px;
  }

  .faq__icon::after {
    width: 2px;
    height: 14px;
    transition: transform 0.2s ease;
  }

  .faq__item[open] .faq__icon::after {
    transform: translate(-50%, -50%) rotate(90deg) scale(0);
  }

  .faq__item p {
    margin: 16px 0 0;
    color: var(--color-text-muted);
    max-width: 65ch;
  }
</style>

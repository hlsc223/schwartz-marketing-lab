---
const footerLinks = [
  { label: 'Services', href: '/#focus' },
  { label: 'Work', href: '/portfolio' },
  { label: 'Blog', href: '/blog' },
  { label: 'Articles', href: '/articles' },
  { label: 'Contact', href: '/contact' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrapper site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__logo">S.LAB</p>
      <p class="site-footer__name">SCHWARTZ MARKETING LAB</p>
      <p class="site-footer__tagline">AEO. SEO. Content.</p>
      <p class="site-footer__copyright">© {year} All rights reserved.</p>
    </div>
    <nav class="site-footer__nav" aria-label="Footer">
      <ul>
        {footerLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border-frame);
    margin-top: 80px;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 32px;
    padding: 48px 24px;
  }

  .site-footer__logo {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 18px;
    margin: 0 0 12px;
  }

  .site-footer__name,
  .site-footer__tagline,
  .site-footer__copyright {
    margin: 0 0 6px;
    font-size: 13px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .site-footer__nav ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-footer__nav a {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>

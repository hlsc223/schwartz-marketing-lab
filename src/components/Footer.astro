---
// Ported from client/src/components/Footer.tsx in the legacy Replit repo.
// See the migration write-up for the full reuse/port/rewrite/remove breakdown.
//
// Reused directly: wordmark markup, literal Tailwind className strings,
// tagline copy, copyright line.
//
// Rewritten for Astro:
//   - Legacy branches on `isHome` (wouter useLocation) to choose between
//     react-scroll <Link> (smooth-scroll anchors) and wouter <Link> (routed
//     hrefs) for the same nav items. Astro has no client router, so this is
//     a single static <a> per link — '/#focus' style hrefs work as plain
//     anchor links on every page (browser handles the in-page scroll on the
//     homepage, and the cross-page navigate-then-scroll on every other page).
//   - InlineEditable tagline (TanStack Query + Express PATCH /api/footer-content)
//     removed — depended on the Replit CMS/backend being removed in this
//     migration. Tagline corrected to "AEO. SEO. Content." after directly
//     capturing the live production footer's rendered text — a prior version
//     of this comment asserted "Modern marketing built for discovery." was
//     the live default; that was wrong, confirmed by direct evidence from the
//     live site rather than the CMS fallback value in the legacy source.
//
// Two link targets needed a decision because they don't resolve cleanly even
// in the legacy site:
//   - "Work" smooth-scrolls to id="work", but no element with that id exists
//     anywhere in Home.tsx's render tree (verified against the homepage
//     component tree) — it's a pre-existing dead anchor in the legacy site.
//     The closest faithful equivalent is the case-studies section (the
//     "Work" you'd actually expect this link to reach), which has
//     id="case-studies" in this Astro port. Pointed there instead of
//     reproducing the broken anchor.
//   - "Articles" previously omitted because /articles hadn't been built yet
//     (would have been a hard 404). /articles now exists as a locked-scope
//     resource page, so the link is restored.
const footerLinks = [
  { label: 'Services', href: '/#focus' },
  { label: 'Work', href: '/#case-studies' },
  { label: 'Blog', href: '/blog' },
  { label: 'Articles', href: '/articles' },
  { label: 'Contact', href: '/contact' },
];

const tagline = 'AEO. SEO. Content.';
const year = new Date().getFullYear();
---

<footer class="bg-background" style="border-top: 1px solid hsl(var(--foreground) / 0.12); padding-top: 40px; padding-bottom: 32px;">
  <div class="max-w-[1100px] mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-5" style="padding-left: clamp(24px, 5vw, 64px); padding-right: clamp(24px, 5vw, 64px);">

    <div>
      <a href="/" class="inline-flex items-baseline gap-2.5 cursor-pointer text-foreground font-sans">
        <span class="font-sans font-black text-base tracking-[-0.02em] text-foreground/90">
          S<span style="color: hsl(var(--cobalt));">.</span>LAB
        </span>
        <span class="text-[10px] font-bold tracking-[0.22em] uppercase text-foreground/45">
          Schwartz Marketing Lab
        </span>
      </a>
      <p class="text-[12px] text-foreground/50 mt-1.5 font-serif">{tagline}</p>
      <p class="text-[11px] text-foreground/30 mt-1">© {year} All rights reserved.</p>
    </div>

    <nav class="flex gap-6 text-[11px] font-bold tracking-[0.1em] uppercase text-foreground/55 font-sans" aria-label="Footer">
      {footerLinks.map((link) => (
        <a href={link.href} class="hover:text-foreground cursor-pointer transition-colors">{link.label}</a>
      ))}
    </nav>

  </div>
</footer>

---
const navLinks = [
  { label: 'Services', href: '/#focus' },
  { label: 'Resources', href: '/blog' },
  { label: 'Packages', href: '/packages' },
  { label: 'About', href: '/about' },
];
---

<header class="site-header">
  <div class="wrapper site-header__inner">
    <a href="/" class="site-header__logo">S.LAB</a>
    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
    <a href="/contact" class="button site-header__cta">Free strategy call</a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: var(--border-frame);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 20px;
    padding-bottom: 20px;
  }

  .site-header__logo {
    font-family: var(--font-heading);
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 0.02em;
  }

  .site-header__nav ul {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav a {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .site-header__cta {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .site-header__nav {
      display: none;
    }
  }
</style>
